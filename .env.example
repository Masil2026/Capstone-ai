# --- Vertex AI ---
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_REGION=global          # LLM용 (gemini-3.1-pro-preview는 global 필요)
GOOGLE_CLOUD_EMBEDDING_REGION=us-central1  # 임베딩용 (text-embedding-004는 regional 필요)

# --- LangSmith (선택) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# LANGCHAIN_API_KEY=your_key
# LANGCHAIN_PROJECT="mju-ai-agent"

# --- Database (Supabase - Pooler Connection) ---
DB_USER=your_key
DB_PASSWORD=your_key
DB_HOST=your_key
DB_PORT=6543
DB_NAME=postgres

# --- Redis (Upstash) ---
REDIS_HOST=your_key
REDIS_PASSWORD=your_key
REDIS_PORT=6379
REDIS_URL=your_key

# --- Server Settings ---
PORT=8000
JAVA_BACKEND_URL=http://localhost:8080

# --- Duffel API (항공 & 숙소) ---
DUFFEL_API_KEY=your_key

# --- Tavily Search API ---
TAVILY_API_KEY=your_key

# --- Google Maps API ---
GOOGLE_MAPS_API_KEY=your_key

# --- Clerk (JWT 인증) ---
CLERK_ISSUER=your_key
CLERK_JWKS_URL=your_key

# --- Internal Token (Spring Boot ↔ FastAPI 서버 간 인증) ---
INTERNAL_TOKEN=your_internal_token